# In development: use /guest-api (proxied by Vite to avoid CORS)
# In production: use the full Apps Script URL directly
VITE_GUEST_API_URL=/guest-api

# Full Google Apps Script URL (used by Vite proxy in development, not exposed to browser)
GUEST_API_TARGET=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
